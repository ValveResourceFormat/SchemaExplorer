{
  "compilerOptions": {
    "target": "esnext",
    "lib": ["dom", "dom.iterable", "es2019"],
    "module": "esnext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "strict": true,
    "noEmit": true,
    "isolatedModules": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "~components/*": ["src/components/*"],
      "~utils/*": ["src/utils/*"]
    }
  },
  "include": ["src", "vite-env.d.ts"]
}
