{
  "compilerOptions": {
    "noEmit": true,
    "strict": true,
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "jsx": "react-jsx",
    "skipLibCheck": true,
    "rootDirs": [
      ".",
      "./.react-router/types"
    ]
  },
  "include": [
    "src",
    "scripts",
    ".react-router/types/**/*"
  ]
}